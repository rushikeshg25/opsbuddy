# HTTP
PORT=8081
CORS_ORIGINS=http://localhost:3000

# Database (TimescaleDB) - DB_USER and DB_PASSWORD are required, no defaults
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=password
DB_NAME=opsbuddy
DB_SSLMODE=disable

# Auth - must match the JWT_SECRET used by the http service
JWT_SECRET=your_jwt_secret

# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash
